%% 直接定位，利用已知的R和fd
t333 = t1 + R0/c0;
pr_t333 = [xr_t3(t333); yr_t3(t333); zr_t3(t333)];
d0 = pr_t333(1);
e0 = pr_t333(2);
f0 = pr_t333(3);
fprintf('Δt = %.12f s\n', abs(t3-t333));

% ---------- 雷达在 t3 时刻速度 ----------
Vx_t333 = 3*x_par_radar(1)*t333^2 + 2*x_par_radar(2)*t333 + x_par_radar(3);
Vy_t333 = 3*y_par_radar(1)*t333^2 + 2*y_par_radar(2)*t333 + y_par_radar(3);
Vz_t333 = 3*z_par_radar(1)*t333^2 + 2*z_par_radar(2)*t333 + z_par_radar(3);
vr_t333 = [Vx_t333; Vy_t333; Vz_t333];

j0 = Vx_t333;
k0 = Vy_t333;
l0 = Vz_t333;
hm_truth = h;

save('C:\Users\eric\Desktop\wyy\各种已知量\data.mat', ...
     'd0','e0','f0','j0','k0','l0','R0','fd0','t222','P_x','hm_truth')
